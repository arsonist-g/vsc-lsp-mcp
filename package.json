{
  "name": "lsp-mcp",
  "displayName": "LSP MCP",
  "version": "0.3.0",
  "description": "LSP MCP Server for VS Code",
  "publisher": "CJL",
  "author": "CJL <2662442385@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/beixiyo/vsc-lsp-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/beixiyo/vsc-lsp-mcp"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/index.js",
  "icon": "res/icon.webp",
  "l10n": "./l10n",
  "files": [
    "LICENSE.md",
    "package.nls.json",
    "package.nls.*.json",
    "dist/*",
    "l10n/*",
    "res/*",
    "CHANGELOG.md"
  ],
  "engines": {
    "vscode": "^1.101.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [],
    "mcpServerDefinitionProviders": [
      {
        "id": "lsp-mcp.localServer",
        "label": "%lsp-mcp.mcpServerDefinitionProvider.localServer.label%"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "%lsp-mcp.configuration.title%",
      "properties": {
        "lsp-mcp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%lsp-mcp.configuration.enabled.description%"
        },
        "lsp-mcp.port": {
          "type": "number",
          "default": 9527,
          "description": "%lsp-mcp.configuration.port.description%"
        },
        "lsp-mcp.cors.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%lsp-mcp.configuration.cors.enabled.description%"
        },
        "lsp-mcp.cors.allowOrigins": {
          "type": "string",
          "default": "*",
          "description": "%lsp-mcp.configuration.cors.allowOrigins.description%"
        },
        "lsp-mcp.cors.withCredentials": {
          "type": "boolean",
          "default": false,
          "description": "%lsp-mcp.configuration.cors.withCredentials.description%"
        },
        "lsp-mcp.cors.exposeHeaders": {
          "type": "string",
          "default": "Mcp-Session-Id",
          "description": "%lsp-mcp.configuration.cors.exposeHeaders.description%"
        },
        "lsp-mcp.maxResults": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "description": "%lsp-mcp.configuration.maxResults.description%"
        },
        "lsp-mcp.outputFormat": {
          "type": "string",
          "default": "json",
          "enum": [
            "json",
            "markdown"
          ],
          "description": "%lsp-mcp.configuration.outputFormat.description%"
        },
        "lsp-mcp.dependencyMarkers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "/node_modules/",
            "/.pnpm/",
            "/.cargo/registry/",
            "/rustlib/",
            "/go/pkg/mod/",
            "/.m2/repository/",
            "/.gradle/caches/",
            "/.venv/",
            "/site-packages/",
            "/vendor/"
          ],
          "description": "%lsp-mcp.configuration.dependencyMarkers.description%"
        },
        "lsp-mcp.mcpLocale": {
          "type": "string",
          "default": "none",
          "enum": [
            "none",
            "en",
            "zh-cn"
          ],
          "description": "%lsp-mcp.configuration.mcpLocale.description%"
        },
        "lsp-mcp.operations.hover": {
          "type": "boolean",
          "default": true,
          "order": 10,
          "description": "%lsp-mcp.configuration.operations.hover.description%"
        },
        "lsp-mcp.operations.definition": {
          "type": "boolean",
          "default": true,
          "order": 11,
          "description": "%lsp-mcp.configuration.operations.definition.description%"
        },
        "lsp-mcp.operations.declaration": {
          "type": "boolean",
          "default": true,
          "order": 12,
          "description": "%lsp-mcp.configuration.operations.declaration.description%"
        },
        "lsp-mcp.operations.type_definition": {
          "type": "boolean",
          "default": true,
          "order": 13,
          "description": "%lsp-mcp.configuration.operations.type_definition.description%"
        },
        "lsp-mcp.operations.implementation": {
          "type": "boolean",
          "default": true,
          "order": 14,
          "description": "%lsp-mcp.configuration.operations.implementation.description%"
        },
        "lsp-mcp.operations.references": {
          "type": "boolean",
          "default": true,
          "order": 20,
          "description": "%lsp-mcp.configuration.operations.references.description%"
        },
        "lsp-mcp.operations.document_highlight": {
          "type": "boolean",
          "default": true,
          "order": 21,
          "description": "%lsp-mcp.configuration.operations.document_highlight.description%"
        },
        "lsp-mcp.operations.prepare_call_hierarchy": {
          "type": "boolean",
          "default": true,
          "order": 30,
          "description": "%lsp-mcp.configuration.operations.prepare_call_hierarchy.description%"
        },
        "lsp-mcp.operations.incoming_calls": {
          "type": "boolean",
          "default": true,
          "order": 31,
          "description": "%lsp-mcp.configuration.operations.incoming_calls.description%"
        },
        "lsp-mcp.operations.outgoing_calls": {
          "type": "boolean",
          "default": true,
          "order": 32,
          "description": "%lsp-mcp.configuration.operations.outgoing_calls.description%"
        },
        "lsp-mcp.operations.document_symbols": {
          "type": "boolean",
          "default": true,
          "order": 40,
          "description": "%lsp-mcp.configuration.operations.document_symbols.description%"
        },
        "lsp-mcp.operations.workspace_symbols": {
          "type": "boolean",
          "default": true,
          "order": 41,
          "description": "%lsp-mcp.configuration.operations.workspace_symbols.description%"
        },
        "lsp-mcp.operations.signature_help": {
          "type": "boolean",
          "default": true,
          "order": 42,
          "description": "%lsp-mcp.configuration.operations.signature_help.description%"
        },
        "lsp-mcp.operations.inlay_hints": {
          "type": "boolean",
          "default": true,
          "order": 43,
          "description": "%lsp-mcp.configuration.operations.inlay_hints.description%"
        },
        "lsp-mcp.operations.document_links": {
          "type": "boolean",
          "default": true,
          "order": 44,
          "description": "%lsp-mcp.configuration.operations.document_links.description%"
        },
        "lsp-mcp.operations.diagnostics": {
          "type": "boolean",
          "default": true,
          "order": 50,
          "description": "%lsp-mcp.configuration.operations.diagnostics.description%"
        },
        "lsp-mcp.operations.workspace_diagnostics": {
          "type": "boolean",
          "default": true,
          "order": 51,
          "description": "%lsp-mcp.configuration.operations.workspace_diagnostics.description%"
        },
        "lsp-mcp.operations.code_actions": {
          "type": "boolean",
          "default": true,
          "order": 60,
          "description": "%lsp-mcp.configuration.operations.code_actions.description%"
        },
        "lsp-mcp.operations.code_action_preview": {
          "type": "boolean",
          "default": true,
          "order": 61,
          "description": "%lsp-mcp.configuration.operations.code_action_preview.description%"
        },
        "lsp-mcp.operations.fix_document_preview": {
          "type": "boolean",
          "default": true,
          "order": 62,
          "description": "%lsp-mcp.configuration.operations.fix_document_preview.description%"
        },
        "lsp-mcp.operations.code_action_apply": {
          "type": "boolean",
          "default": true,
          "order": 63,
          "description": "%lsp-mcp.configuration.operations.code_action_apply.description%"
        },
        "lsp-mcp.operations.prepare_rename": {
          "type": "boolean",
          "default": true,
          "order": 70,
          "description": "%lsp-mcp.configuration.operations.prepare_rename.description%"
        },
        "lsp-mcp.operations.rename_preview": {
          "type": "boolean",
          "default": true,
          "order": 71,
          "description": "%lsp-mcp.configuration.operations.rename_preview.description%"
        },
        "lsp-mcp.operations.rename_apply": {
          "type": "boolean",
          "default": true,
          "order": 72,
          "description": "%lsp-mcp.configuration.operations.rename_apply.description%"
        },
        "lsp-mcp.operations.class_file_contents": {
          "type": "boolean",
          "default": true,
          "order": 80,
          "description": "%lsp-mcp.configuration.operations.class_file_contents.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --sourcemap",
    "lint": "eslint src --fix",
    "vscode:prepublish": "pnpm build",
    "vsix": "vsce package --no-dependencies --out lsp-mcp.vsix",
    "release:prepare": "pnpm test && pnpm typecheck && pnpm vsix",
    "release:vscode": "pnpm release:prepare && vsce publish --no-dependencies --packagePath lsp-mcp.vsix",
    "release:open-vsx": "pnpm release:prepare && ovsx publish --no-dependencies lsp-mcp.vsix",
    "release:all": "pnpm release:prepare && vsce publish --no-dependencies --packagePath lsp-mcp.vsix && ovsx publish --no-dependencies lsp-mcp.vsix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "express": "^5.1.0",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.2.1",
    "@types/express": "^5.0.3",
    "@types/node": "^22.13.4",
    "@types/vscode": "1.101.0",
    "@vscode/vsce": "^3.2.2",
    "eslint": "^9.20.1",
    "ovsx": "^1.0.2",
    "reactive-vscode": "^0.2.10",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vitest": "3.0.5"
  }
}
